# ─── Auth Service ──────────────────────────────────────────────
# From Supabase → Project Settings → Database → Connection string (URI mode)
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<db>?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-db-password

# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-256-bit-string

# Railway sets this automatically — do not change
PORT=8081
