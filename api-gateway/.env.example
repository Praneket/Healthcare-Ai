# ─── API Gateway ───────────────────────────────────────────────
# Paste the Railway public URLs of each deployed service below
AUTH_SERVICE_URL=https://auth-service.up.railway.app
DIAGNOSIS_SERVICE_URL=https://diagnosis-service.up.railway.app
PATIENT_SERVICE_URL=https://patient-records-service.up.railway.app
NOTIFICATION_SERVICE_URL=https://notification-service.up.railway.app

# Must be the same secret used in auth-service
JWT_SECRET=replace-with-a-random-256-bit-string

# Railway sets this automatically — do not change
PORT=8080
