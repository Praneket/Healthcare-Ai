# ─── Diagnosis Service ─────────────────────────────────────────
# From Upstash Redis → Connect → .env tab
SPRING_REDIS_HOST=your-upstash-redis-host.upstash.io
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your-upstash-redis-password
SPRING_REDIS_SSL=true

# From Upstash Kafka → Connect → Properties tab
SPRING_KAFKA_BOOTSTRAP_SERVERS=your-upstash-kafka-endpoint:9092
KAFKA_SASL_USERNAME=your-upstash-kafka-username
KAFKA_SASL_PASSWORD=your-upstash-kafka-password

# Railway public URL of the deployed ai-service
AI_SERVICE_URL=https://ai-service.up.railway.app

# Railway sets this automatically — do not change
PORT=8082
